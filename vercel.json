{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "branches": [
    {
      "name": "master",
      "production": true
    },
    {
      "name": "build",
      "production": false
    }
  ],
  "rewrites": [
    {
      "source": "/react-portfolio/:path*",
      "destination": "/react-portfolio/index.html"
    }
  ]
}
